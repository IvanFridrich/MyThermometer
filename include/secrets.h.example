#pragma once
// =============================================================================
//  secrets.h.example — template for WiFi / SMTP credentials.
//
//  HOW TO USE:
//    1. Copy this file to include/secrets.h
//    2. Fill in the real values below.
//    3. Never commit include/secrets.h — it is in .gitignore.
//
//  All symbols here are consumed by src/app/ modules via #include "secrets.h".
//  They are intentionally preprocessor macros (not cfg:: constants) so that
//  the linker strips them from the binary string table in release builds.
// =============================================================================

// WiFi credentials
#define WIFI_SSID "YourSSID"
#define WIFI_PASSWORD "YourPassword"

// SMTP / email alarm (Gmail recommended: use an App Password, not your login password)
#define SMTP_HOST "smtp.gmail.com"
#define SMTP_USER "you@gmail.com"
#define SMTP_PASS "your-app-password"
#define RECIPIENT_EMAIL "recipient@example.com"
